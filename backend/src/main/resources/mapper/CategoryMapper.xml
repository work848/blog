<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.CategoryMapper">

    <resultMap id="categoryResultMap" type="com.blog.entity.Category">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="color" column="color"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.blog.entity.Category" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, color, created_at)
        VALUES (#{name}, #{color}, #{createdAt})
    </insert>

    <update id="update" parameterType="com.blog.entity.Category">
        UPDATE category
        SET name = #{name},
            color = #{color}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM category WHERE id = #{id}
    </delete>

    <select id="findById" resultMap="categoryResultMap">
        SELECT * FROM category WHERE id = #{id}
    </select>

    <select id="findByName" resultMap="categoryResultMap">
        SELECT * FROM category WHERE name = #{name}
    </select>

    <select id="findAll" resultMap="categoryResultMap">
        SELECT * FROM category ORDER BY created_at
    </select>
</mapper>
