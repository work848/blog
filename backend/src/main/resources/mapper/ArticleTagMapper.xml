<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.ArticleTagMapper">

    <insert id="insert">
        INSERT INTO article_tag (article_id, tag_id)
        VALUES (#{articleId}, #{tagId})
    </insert>

    <delete id="deleteByArticleId">
        DELETE FROM article_tag WHERE article_id = #{articleId}
    </delete>

    <delete id="deleteByTagId">
        DELETE FROM article_tag WHERE tag_id = #{tagId}
    </delete>

    <select id="findTagIdsByArticleId" resultType="long">
        SELECT tag_id FROM article_tag WHERE article_id = #{articleId}
    </select>
</mapper>
